# Laundry Booking System Configuration

# Server Configuration
PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Security Question Answer (street number * number of floors including roof)
# Example: if street number is 42 and building has 6 floors including roof = 42 * 6 = 252
SECURITY_ANSWER=252

# Email Configuration (optional - for overtime notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Database (SQLite file will be created automatically)
DB_PATH=./laundry_booking.db